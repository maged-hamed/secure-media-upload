{
    "name": "maged/secure-media-upload",
    "description": "Secure and extensible media uploads for Laravel with strict validation and local/S3 support.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "upload", "s3", "media", "security"],
    "require": {
        "php": "^8.2",
        "ext-fileinfo": "*",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Maged\\SecureMediaUpload\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Maged\\SecureMediaUpload\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maged\\SecureMediaUpload\\MediaUploadServiceProvider"
            ],
            "aliases": {
                "SecureMediaUpload": "Maged\\SecureMediaUpload\\Facades\\SecureMediaUpload"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
